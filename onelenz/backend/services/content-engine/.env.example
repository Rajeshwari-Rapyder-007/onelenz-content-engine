# Content Engine — environment variables
# Copy to .env and fill in secrets before running.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/onelenz
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=dev

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000

# JWT (RS256 public key only — verifies tokens, does not sign)
JWT_PUBLIC_KEY=

# S3
S3_BUCKET_CONTENT=onelenz-content-engine
AWS_REGION=ap-south-1

# Celery (uses Redis DB 2)
CELERY_BROKER_URL=redis://localhost:6379/2

# Bedrock (Titan V2 embeddings)
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_DIMENSIONS=1024
BEDROCK_MAX_BATCH_SIZE=25

# Docling extraction
DOCLING_MAX_NUM_PAGES=200
DOCLING_MAX_FILE_SIZE=52428800
# Enable OCR for scanned PDFs (CPU-based, no GPU needed)
# Adds ~30-60s per scanned page. Digital PDFs unaffected.
# Uses EasyOCR by default. Set true only if needed.
DOCLING_ENABLE_OCR=false
# Limit Docling CPU threads in workers
OMP_NUM_THREADS=4

# Chunking (Docling HybridChunker)
CHUNK_MAX_TOKENS=512


# Crawling (Crawl4AI)
CRAWL_MAX_DEPTH=1
CRAWL_MAX_PAGES=50
CRAWL_INCLUDE_EXTERNAL=false
CRAWL_TIMEOUT_SECONDS=120
CRAWL_LISTING_LINK_THRESHOLD=5

# Ingestion
MAX_FILE_SIZE_BYTES=52428800
MAX_FILES_PER_UPLOAD=20
MAX_ASSETS_PER_DAY_PER_ENTITY=100
INGESTION_TASK_RETRIES=3
ALLOWED_FILE_TYPES=pdf,docx,pptx,xlsx,txt,zip
MAX_ZIP_DECOMPRESSED_BYTES=209715200
MAX_FILES_PER_ZIP=50

# Credits
CREDITS_PER_PAGE=0.5

# Signal matching
MATCH_RESULT_LIMIT=3
MATCH_RESULT_MAX=5
SIMILARITY_THRESHOLD=0.65

# Internal service auth (for KH-0 signup trigger)
INTERNAL_SERVICE_KEY=