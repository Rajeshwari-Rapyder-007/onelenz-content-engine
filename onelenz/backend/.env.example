# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/onelenz
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=dev

# Logging
LOG_LEVEL=DEBUG

# CORS
CORS_ORIGINS=http://localhost:3000

# JWT (RS256) — PEM content, not file paths. In production, injected from AWS Secrets Manager.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=2
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=15

# Auth Service
LOCKOUT_THRESHOLD=3
LOCKOUT_DURATION_MINUTES=30

# Email (OTP)
EMAIL_PROVIDER=mock
AWS_SES_FROM_EMAIL=noreply@onelenz.ai
AWS_SES_REGION=ap-south-1
OTP_EXPIRY_MINUTES=10

# Email Connector — Microsoft OAuth
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
MS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
# Note: MS_OAUTH_REDIRECT_URI is derived from FRONTEND_URL — no separate env var needed

# Email Connector — Token Encryption
TOKEN_ENCRYPTION_KEY=

# Email Connector — S3
S3_BUCKET_EMAILS=onelenz-emails
AWS_REGION=ap-south-1

# Email Connector — Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_CONCURRENCY=10

# Email Connector — Sync
SYNC_FREQUENCY_MINUTES=15
TOKEN_REFRESH_BUFFER_MINUTES=5
INITIAL_FETCH_DAYS=30
MAX_FETCH_DAYS=90

# Frontend
FRONTEND_URL=http://localhost:3000
